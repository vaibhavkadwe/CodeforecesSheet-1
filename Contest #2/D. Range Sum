#include <iostream>
using namespace std;

int main() {
    int t;
    cin>>t;
    long long l,r;
    long long sum,suml,sumr;
    long long* sum1 = new long long[t]; 
    for(int i=0;i<t;i++){
        cin>>l>>r;
        if(l>r){
            swap(l,r);
        }
        sumr = r * (r+1)/2;
        suml = l * (l-1)/2;
        sum = sumr - suml;
        sum1[i]=sum;
    }
    for(int i=0;i<t;i++){
        cout<<sum1[i]<<endl;
    }
    delete[] sum1;
    return 0;
}