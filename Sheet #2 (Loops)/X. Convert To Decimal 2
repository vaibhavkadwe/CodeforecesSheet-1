#include<iostream>
using namespace std;

int main(){
    int t,x;
    int count=0;
    cin>>t;
    for(int i=0;i<t;i++){
        cin>>x;
        while(x>0){
            if(x%2==1){
                count++;
            }
            x=x/2;
        }
        cout<<(1LL<<count)-1<<endl;
        count = 0;
    }
    return 0;
}