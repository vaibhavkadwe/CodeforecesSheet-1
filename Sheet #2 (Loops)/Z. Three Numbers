#include<iostream>
using namespace std;
int main(){
    int n,ans;
    cin>>n>>ans;
    int count=0;
    for(int i=0;i<=n;i++){
        for(int j=0;j<=n;j++){
            int k=ans-i-j;
            if(k>=0 && k<=n){
                count++;
            }
        }
    }
    cout<<count;
    return 0;
}