#include<iostream>
using namespace std;

int main(){
    int n;
    cin>>n;
    int* arr = new int[n];
    for(int i=0;i<n;i++){
        cin>>arr[i];
    }
    int min_i=0;
    for(int i=0;i<n;i++){
        min_i=i;
        for(int j=i+1;j<n;j++){
            if(arr[j]<arr[min_i]){
               min_i=j;
            }
        }
        swap(arr[i],arr[min_i]);
    }

    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }

    delete[] arr;
    return 0;
}